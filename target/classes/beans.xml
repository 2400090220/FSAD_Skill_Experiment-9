<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans.xsd">
        
        <bean id="helloworld" class="model.HelloWorld">
             <property name="message" value="Hello World from Dependency Injection"></property>
        </bean>
	<bean id="student" class="model.Student">
		<property name="rollno" value="1001"></property>
		<property name="name" value="xxxxxxx"></property>	
		<property name="department" value="CSE"></property>
		<property name="cgpa" value="9.2"></property>
	</bean>
	<bean id="person" class="model.Person">
    <constructor-arg name="name" value="XXXXXX"></constructor-arg>
    <constructor-arg name="age" value="40"></constructor-arg>
    <constructor-arg name="emailid" value="xxx@xyz.com"></constructor-arg>
 
	</bean>
</beans>